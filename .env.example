DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dbname
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dbname_test

# PyArch auth integration
AUTH_JWT__ALGORITHM=RS256
AUTH_JWT__ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_JWT__REFRESH_TOKEN_EXPIRE_DAYS=30
# AUTH_JWT__PUBLIC_KEY_PATH=certs/public.pem
# AUTH_JWT__PRIVATE_KEY_PATH=certs/private.pem

# S3-compatible object storage (AWS S3, MinIO, Cloudflare R2, etc.)
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_BUCKET=lotus-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=lotus-root
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=true
S3_PRESIGNED_URL_EXPIRE_SECONDS=900

# Item image upload limits
ITEM_IMAGES_MAX_COUNT=10
ITEM_IMAGE_MAX_SIZE_BYTES=5242880
ITEM_IMAGE_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp

# Redis-backed cache and rate limiting
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=1
REDIS_SOCKET_TIMEOUT_SECONDS=1
WS_PUBSUB_ENABLED=true
WS_PUBSUB_CHANNEL=lotus:v1:auction-events
WS_PUBSUB_RECONNECT_DELAY_SECONDS=1
WS_PUBSUB_LOCAL_FALLBACK=true
CACHE_ENABLED=true
CACHE_FAIL_OPEN=true
AUCTION_CACHE_TTL_SECONDS=30
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_OPEN=false
AUTH_REGISTER_RATE_LIMIT_LIMIT=5
AUTH_REGISTER_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_IP_RATE_LIMIT_LIMIT=20
AUTH_LOGIN_IP_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_USERNAME_RATE_LIMIT_LIMIT=8
AUTH_LOGIN_USERNAME_RATE_LIMIT_WINDOW_SECONDS=300
BID_USER_RATE_LIMIT_LIMIT=30
BID_USER_RATE_LIMIT_WINDOW_SECONDS=60
BID_LOT_RATE_LIMIT_LIMIT=120
BID_LOT_RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
# Use "json" in containerized deployments that are collected by ELK/Loki agents.
LOG_FORMAT=plain

# Celery and RabbitMQ background jobs
CELERY_TASKS_ENABLED=true
CELERY_BROKER_URL=pyamqp://guest:guest@127.0.0.1:5672//
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true
CELERY_BROKER_CONNECTION_TIMEOUT_SECONDS=1
AUCTION_LIFECYCLE_SYNC_INTERVAL_SECONDS=60
AUCTION_LIFECYCLE_SYNC_LIMIT=100
SALE_CONFIRMATION_DELAY_SECONDS=30
IDEMPOTENCY_KEY_TTL_SECONDS=86400
CLEANUP_INTERVAL_SECONDS=3600
REFRESH_SESSION_CLEANUP_RETENTION_DAYS=7

# Empty means same-origin only. Use comma-separated origins for a browser frontend.
CORS_ALLOWED_ORIGINS=
