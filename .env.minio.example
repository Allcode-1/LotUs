# Copy this file to .env.minio on the VPS and replace all secrets.
#
# MinIO root credentials are equivalent to S3 access/secret keys.
# Use long random values and do not commit .env.minio.
MINIO_ROOT_USER=lotus-root
MINIO_ROOT_PASSWORD=change-me-to-a-long-random-password

# Default bucket created by the minio-init service.
MINIO_DEFAULT_BUCKET=lotus-media

# Valid values: none, download, upload.
# Keep "none" for a private bucket and generate presigned URLs from the backend.
MINIO_DEFAULT_BUCKET_ANONYMOUS_POLICY=none
MINIO_BUCKET_REGION=us-east-1

# Host ports exposed on the VPS.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Images can be pinned to specific RELEASE tags later.
MINIO_IMAGE=quay.io/minio/minio:latest
MINIO_MC_IMAGE=quay.io/minio/mc:latest
